library project Prj is

   type BUILD_KIND is ("static", "relocatable");
   Library_Type : BUILD_KIND := external ("LIBRARY_TYPE", "static");

   for Languages use ("Ada");
   for Source_Dirs use ("src");

   case Library_Type is
      when "static" =>
         for Languages use Project'Languages & ("C");
         for Source_Dirs use Project'Source_Dirs & ("c-src");
      when "relocatable" =>
         null;
   end case;

   for Library_Name use "lang";
   for Library_Kind use Library_Type;
   for Library_Dir use "lib/" & Project'Library_Kind;
   for Object_Dir use "obj/" & Project'Library_Kind;

end Prj;
