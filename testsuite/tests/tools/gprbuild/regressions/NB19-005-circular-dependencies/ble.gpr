with "c.gpr";
limited with "k_bla0.gpr";

Library project Ble is

   for Library_Name use "ble";
   for Library_Kind use "static";
   for Library_Dir use "lib";

   for Object_Dir use "obj";

   for Source_Dirs use ("ble");

   for Library_Dir use "lib";

   package Compiler is
      for Default_Switches ("Ada") use C.Compiler'Default_Switches("Ada");
      for Default_Switches ("C") use C.Compiler'Default_Switches("C");
   end Compiler;

   package Binder is
      for Default_Switches use C.Binder'Default_Switches;
   end Binder;

end Ble;
