with "c.gpr";
with "k_bla4.gpr";
with "k_bla0.gpr";
limited with "ie_bla4.gpr";
limited with "ie_be_bla0.gpr";
library project IE_BLA0 is

   for Source_Dirs use ("c_bla0");
   for Languages use ( "Ada");
   for Library_Name use "libIE_bla0";
   for Library_Dir use "lib";
   for Object_Dir use "obj";

   package Compiler is
      for Default_Switches ("ada") use C.Compiler'Default_Switches ("Ada");
   end Compiler;

   package Binder is
      for Default_Switches use C.Binder'Default_Switches;
   end Binder;

end IE_BLA0;

